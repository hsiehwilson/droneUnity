package datasource {

    abstract class Prefab extends "unity.GameObject" {

    }
    note right of Prefab {
        script field is the name of the script
        associated with the prefab
        (e.g. ChargingBlockPrefab uses
        "ChargingBlock" in script package)
    }

    class DronePrefab <<Prefab>> extends Prefab {

    }

    class ChargingBlockPrefab <<Prefab>> extends Prefab {
        -ChargingBlock: Script
    }

    class ArrowDrawerPrefab <<Prefab>> extends Prefab {
        -ArrowDrawer: Script
    }

    class DefaultSaddleCubePrefab <<Prefab>> extends Prefab {

    }

    class InvertSaddleCubePrefab <<Prefab>> extends Prefab {

    }
    class WallPrefab <<Prefab>> extends Prefab {

    }

    package CSVFiles {

        class File1 <<CSVfile>> {
            +columns: [timestamp, droneId, x, y, z]
            +rows: drone
        }

        note left of File1 {
            There are 587 such files that contain
            drone data for each step in the simulation
        }

    }

    class changes <<CSVfile>> {
        +columns: [mode, x, y, z, subtract direction]
        +rows: next cube generation step
    }

    note left of changes {
        This is the master CSV file that
        creates the other 587 files
    }

    "scripts.CubeHelper" ..> changes
    "scripts.AutoCameraController" ..> changes
    "scripts.AutoCameraController" ..> File1
    "scripts.CSVLogic" ..> changes
    "scripts.CSVLogic" ..> File1

}

