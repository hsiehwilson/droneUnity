package unity {

    abstract class GameObject {
        +Instaniate(prefab: Prefab): void
        +Destroy(): void
    }

    note left of GameObject {
        Instantiate() method is the constructor
        Destroy() method removes the instance entirely
    }


    class DroneManager <<GameObject>> extends GameObject {
    }


    class Panel <<GameObject>> extends GameObject {
        CubeVisualizationToggle: GameObject
        IntensitySlider: GameObject
    }

